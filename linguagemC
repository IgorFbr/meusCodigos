using UnityEngine;

public class desafio : MonoBehaviour
{
   
    public string letra;

    void Start()
    {
        if (letra == "")
        {
            Debug.Log("Insira uma letra");
        }
        else if (letra == "a" || letra == "e" || letra == "i" || letra == "o" || letra == "u")
        {
            Debug.Log(letra + " é uma vogal");
        }
        else
        {
            Debug.Log(letra + " é uma consoante");
        }
    }

    void Update()
    {

    }
}
